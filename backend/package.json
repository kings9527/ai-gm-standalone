{
  "name": "ai-gm-backend",
  "version": "0.1.0",
  "description": "AI-GM standalone backend — RPG engine + LLM + storage",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --test test/**/*.test.js",
    "test:coverage": "c8 --all npm test",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint --fix src/ test/",
    "format": "prettier --write 'src/**/*.js' 'test/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'test/**/*.js'",
    "check": "node --check src/index.js && node --check src/**/*.js"
  },
  "dependencies": {
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "pg": "^8.12.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "c8": "^10.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
