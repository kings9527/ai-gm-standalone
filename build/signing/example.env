# Code Signing Environment Variables Template
# Copy this file and fill in your actual credentials for signed builds.
# NEVER commit real credentials to git.

# =============================================================================
# WINDOWS (PFX Certificate)
# =============================================================================
# Path to your .pfx code signing certificate
WIN_CSC_LINK=file:///absolute/path/to/certificate.pfx
# Password for the PFX file
WIN_CSC_KEY_PASSWORD=your-pfx-password

# =============================================================================
# macOS (Apple Developer ID)
# =============================================================================
# Certificate name as shown in Keychain Access (with "Developer ID Application:" prefix)
CSC_NAME=Developer ID Application: Your Name (XXXXXXXXXX)
# Enable automatic discovery from keychain
CSC_IDENTITY_AUTO_DISCOVERY=true

# Apple ID for notarization
APPLE_ID=your-apple-id@example.com
# App-specific password (NOT your Apple ID password!)
APPLE_ID_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Apple Team ID (10 characters)
APPLE_TEAM_ID=XXXXXXXXXX

# =============================================================================
# Optional: Specify keychain if not using default login keychain
# =============================================================================
# CSC_KEYCHAIN=~/Library/Keychains/login.keychain-db
